# Pageden — copy to .env and fill in. Never commit the real .env.
# Resolves review item: missing .env.example (fresh clone must start from documented commands).

# ---- PostgreSQL ----
POSTGRES_DB=pageden
POSTGRES_USER=pageden
POSTGRES_PASSWORD=pageden_dev_password

# ---- Server (apps/server) ----
NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://pageden:pageden_dev_password@localhost:5432/pageden

# Seals the stateless web session cookie. Use a long random string in production.
SESSION_SECRET=replace-in-development-session-secret-32-plus-chars

# HMAC key used to hash Obsidian plugin tokens (deterministic lookup — see api-contract B5).
# Rotating this value invalidates every existing plugin token.
TOKEN_HASH_SECRET=replace-in-development-token-secret-32-plus-chars

# Where Markdown content files are written.
STORAGE_ROOT=./storage

# Canonical app origin. In self-hosted mode this is the only app URL.
APP_URL=http://localhost:3000

# Workspace subdomain routing is cloud-only. Keep false for self-hosted installs.
CLOUD_HOSTED=false
BASE_DOMAIN=pageden.com

# CORS allowed origin for the web app (cookie auth).
WEB_ORIGIN=http://localhost:3000

# First-admin bootstrap, consumed by `pnpm db:seed` (resolves chicken-and-egg, review H6).
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=change-me

# ---- Web (apps/web — Vite/TanStack Start) ----
# Must be VITE_-prefixed to reach the browser bundle. With the dev proxy, set this to /api.
VITE_API_BASE_URL=http://localhost:4000/api
VITE_WORKSPACE_BASE_DOMAIN=pageden.app

# Transactional email (password reset). Without RESEND_API_KEY, reset links are logged to the
# server console (fine for local dev). Set both in production.
RESEND_API_KEY=
MAIL_FROM=Pageden <no-reply@example.com>

# Google sign-in (optional). Create an OAuth 2.0 Client (Web) in Google Cloud; set the authorized
# redirect URI to <APP_URL>/api/auth/google/callback. Leave unset to disable Google sign-in.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=   # optional override; defaults to <APP_URL>/api/auth/google/callback

# Set AUTH_ALLOW_SIGNUP=false to disable open self-signup (invite/admin-created accounts only).
