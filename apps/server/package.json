{
  "name": "@pageden/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "dotenv -e ../../.env -- tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run -c vitest.config.ts",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate deploy",
    "db:migrate:dev": "dotenv -e ../../.env -- prisma migrate dev",
    "db:generate": "prisma generate",
    "db:seed": "dotenv -e ../../.env -- tsx prisma/seed.ts",
    "test:integration": "dotenv -e ../../.env.test -e ../../.env -- vitest run -c vitest.integration.config.ts",
    "storage:sweep": "dotenv -e ../../.env -- tsx scripts/sweep-orphans.ts",
    "search:backfill": "tsx scripts/backfill-search.ts",
    "test:coverage": "dotenv -e ../../.env.test -e ../../.env -- vitest run -c vitest.coverage.config.ts",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed:deploy": "tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.658.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/rate-limit": "^11.0.0",
    "@fastify/websocket": "^11.2.0",
    "@pageden/api-types": "workspace:*",
    "@prisma/client": "^5.18.0",
    "arctic": "^3.7.0",
    "argon2": "^0.44.0",
    "fastify": "^5.8.5",
    "lib0": "^0.2.117",
    "ws": "^8.21.0",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.31",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "2.1.9",
    "prisma": "^5.18.0",
    "tsx": "^4.16.5",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
