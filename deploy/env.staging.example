# Pageden STAGING (go.pageden.io). Copy to .env.staging; never commit. chmod 600.
APP_URL=https://go.pageden.io
WEB_ORIGIN=https://go.pageden.io
BASE_DOMAIN=pageden.io
CLOUD_HOSTED=false

# openssl rand -hex 32  (MUST differ from production)
SESSION_SECRET=
TOKEN_HASH_SECRET=

# Managed Postgres — its OWN database (separate from prod). Keep sslmode=require.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:25060/pageden_staging?sslmode=require

# Storage: a dedicated private Space (separate from prod).
STORAGE_DRIVER=spaces
SPACES_BUCKET=pageden-staging
SPACES_REGION=sgp1
SPACES_ENDPOINT=https://sgp1.digitaloceanspaces.com
SPACES_ACCESS_KEY_ID=
SPACES_SECRET_ACCESS_KEY=
SPACES_FORCE_PATH_STYLE=false

BOOTSTRAP_ADMIN_EMAIL=admin@pageden.io
BOOTSTRAP_ADMIN_PASSWORD=change-me-now

AUTH_ALLOW_SIGNUP=true

EMAIL_PROVIDER=log
MAIL_FROM=Pageden Staging <no-reply@pageden.app>
BREVO_API_KEY=
RESEND_API_KEY=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://go.pageden.io/api/auth/google/callback
