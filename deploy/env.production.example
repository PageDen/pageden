# Pageden PRODUCTION (go.pageden.app). Copy to .env.production; never commit. chmod 600.
APP_URL=https://go.pageden.app
WEB_ORIGIN=https://go.pageden.app
BASE_DOMAIN=pageden.app
CLOUD_HOSTED=false

# openssl rand -hex 32  (MUST differ from staging)
SESSION_SECRET=
TOKEN_HASH_SECRET=

# Managed Postgres — its OWN database (not shared with staging). Keep sslmode=require.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:25060/pageden_prod?sslmode=require

# Storage: a dedicated private Space (separate from staging).
STORAGE_DRIVER=spaces
SPACES_BUCKET=pageden-prod
SPACES_REGION=sgp1
SPACES_ENDPOINT=https://sgp1.digitaloceanspaces.com
SPACES_ACCESS_KEY_ID=
SPACES_SECRET_ACCESS_KEY=
SPACES_FORCE_PATH_STYLE=false

BOOTSTRAP_ADMIN_EMAIL=admin@pageden.app
BOOTSTRAP_ADMIN_PASSWORD=change-me-now

# Production keeps signup CLOSED until abuse controls land (Task #44). Flip on deliberately.
AUTH_ALLOW_SIGNUP=false

EMAIL_PROVIDER=log
MAIL_FROM=Pageden <no-reply@pageden.app>
BREVO_API_KEY=
RESEND_API_KEY=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://go.pageden.app/api/auth/google/callback
