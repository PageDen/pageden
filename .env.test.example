# Pageden — copy to .env.test for LOCAL integration/coverage tests.
# Integration tests TRUNCATE every table between tests, so they MUST point at a
# throwaway database — never your dev DB. Create it once (Postgres must be running):
#
#   docker compose exec -T postgres psql -U pageden -d pageden -c "CREATE DATABASE pageden_test;"
#   pnpm --filter @pageden/server exec dotenv -e ../../.env.test -- prisma migrate deploy
#
# Only DATABASE_URL is required here; the test setup supplies the other vars.
DATABASE_URL=postgresql://pageden:pageden_dev_password@localhost:5432/pageden_test
